tenant_name      = "tn-tech-elevate"
vrf_name         = "vrf-01"
contract_prefix  = "permit-to"
consumed_contract_prefix = "permit-from"
intra_contract_prefix = "permit-intra"
contract_scope = "context" # default fallback; valid: context, tenant, global
default_provided_contract_consumer_esg_dns = ["uni/tn-tech-elevate/ap-external-subnets/esg-all-external-subnets"]
default_consumed_contract_provider_dns     = ["uni/tn-tech-elevate/brc-permit-to-all-external-subnets"]
k8s_applications_yaml_file = "k8s-applications.yaml"

# Keep empty when using YAML file input.
k8s_applications = {}

